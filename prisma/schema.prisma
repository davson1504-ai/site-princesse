generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  REFUSED
  CANCELLED
  COMPLETED
  ARCHIVED
}

model Appointment {
  id                     String            @id @default(cuid())
  reference              String            @unique
  customerName           String
  phone                  String
  whatsapp               String
  email                  String?
  appointmentDate        DateTime
  appointmentTime        String
  location               String
  appointmentType        String
  preferredContactMethod String
  message                String?
  status                 AppointmentStatus @default(PENDING)
  notificationErrors     Json?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  service                Service           @relation(fields: [serviceId], references: [id])
  serviceId              String
  hairstyle              Hairstyle?        @relation(fields: [hairstyleId], references: [id])
  hairstyleId            String?

  @@unique([appointmentDate, appointmentTime])
  @@index([status, appointmentDate])
}

model Service {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  description  String
  duration     String
  price        String?
  image        String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
}

model Hairstyle {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  category      String
  description   String
  duration      String
  price         String?
  mainImage     String
  galleryImages String[]
  isFeatured    Boolean       @default(false)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  appointments  Appointment[]
}
