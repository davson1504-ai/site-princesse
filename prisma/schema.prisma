generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  REFUSED
  CANCELLED
  COMPLETED
  ARCHIVED
}

enum NotificationChannel {
  EMAIL_ADMIN
  EMAIL_CUSTOMER
  WHATSAPP_META
}

model Appointment {
  id                     String            @id @default(cuid())
  reference              String            @unique
  customerName           String
  phone                  String
  whatsapp               String
  email                  String?
  appointmentDate        DateTime
  appointmentTime        String
  appointmentDateTime    DateTime
  endsAt                 DateTime
  timezone               String            @default("Europe/Paris")
  durationMinutes        Int
  quotedPrice            String?
  location               String
  appointmentType        String
  preferredContactMethod String
  message                String?
  status                 AppointmentStatus @default(PENDING)
  notificationErrors     Json?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  service                Service           @relation(fields: [serviceId], references: [id])
  serviceId              String
  hairstyle              Hairstyle?        @relation(fields: [hairstyleId], references: [id])
  hairstyleId            String?
  notifications          NotificationLog[]

  @@index([status, appointmentDate])
  @@index([appointmentDateTime, endsAt])
}

model Service {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  description  String
  duration     String
  durationMinutes Int
  price        String?
  image        String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
}

model NotificationLog {
  id             String              @id @default(cuid())
  appointment    Appointment         @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  appointmentId  String
  channel        NotificationChannel
  success        Boolean
  providerId     String?
  sanitizedError String?
  createdAt      DateTime            @default(now())

  @@index([appointmentId, channel, createdAt])
  @@index([success, createdAt])
}

model AdminAuditLog {
  id        String   @id @default(cuid())
  action    String
  targetRef String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([action, createdAt])
}

model BlockedSlot {
  id        String   @id @default(cuid())
  startsAt  DateTime
  endsAt    DateTime
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startsAt, endsAt])
}

model RateLimitBucket {
  key       String   @id
  count     Int
  resetAt   DateTime
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

model Hairstyle {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  category      String
  description   String
  duration      String
  price         String?
  mainImage     String
  galleryImages String[]
  isFeatured    Boolean       @default(false)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  appointments  Appointment[]
}
